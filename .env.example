# 本文件是示例模板，可以复制为 .env 后填入本机密钥。
# .env 已被 .gitignore 忽略，不应提交真实密钥。

ASR_PROVIDER=baidu-realtime
ASR_APP_ID=你的百度 AppID
ASR_API_KEY=你的百度 AppKey
ASR_BAIDU_WS_URL=wss://vop.baidu.com/realtime_asr
ASR_BAIDU_CUID=ai_interpreter_windows
ASR_BAIDU_DEV_PID=auto
ASR_TIMEOUT_SECONDS=30

PARTIAL_TRANSLATION_PROVIDER=baidu-mt
PARTIAL_TRANSLATION_APP_ID=your_baidu_mt_app_id
PARTIAL_TRANSLATION_API_KEY=your_baidu_mt_api_key
PARTIAL_TRANSLATION_SECRET_KEY=your_baidu_mt_secret_key
PARTIAL_TRANSLATION_TIMEOUT_SECONDS=10

SOURCE_LANGUAGE=en
TARGET_LANGUAGE=zh-CN
SUBTITLE_MODE=bilingual
# 可选；不配置时保存到当前用户的本地应用数据目录。
TRANSCRIPT_STORAGE_DIR=
LOG_LEVEL=INFO
